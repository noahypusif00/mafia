<script>
// ==================== GAME STATE ====================
let gameState = {
  adminName: '',
  winCondition: 1, // 1 or 2
  players: [], // {id, name, role, card, alive, muted, mutedNextDay, healed, revealed, sniperUsed, avatar}
  day: 1,
  phase: 'day', // day, night, voting
  nightStep: 0, // 0=none, 1=mafiaKill, 2=mafiaMute, 3=doctor, 4=sniper, 5=detective, 6=dayBreak
  nightActions: {}, // {killTarget, muteTarget, healTarget, sniperTarget, detectiveTarget}
  votes: {}, // playerId -> targetId
  eventLog: [],
  gameOver: false,
  currentView: 'admin', // admin, player, spectator
  currentPlayerId: null,
  cardsRevealed: false
};

const ROLES = {
  RED_ACE: { id: 'red_ace', name: 'آس أحمر', icon: '🃏', color: '#ff4757', team: 'mafia', desc: 'مافيا القتل - تستيقظ في الليل لتختار ضحية' },
  BLACK_ACE: { id: 'black_ace', name: 'آس أسود', icon: '🃏', color: '#555', team: 'mafia', desc: 'مافيا التسكيت - تختار شخصاً لمنعه من الكلام والتصويت' },
  BOY: { id: 'boy', name: 'الولد الصالح', icon: '👦', color: '#00d9a3', team: 'citizen', desc: 'إذا مات، يسحب معه أي شخص يختاره' },
  OLD_MAN: { id: 'old_man', name: 'الشايب', icon: '👴', color: '#3498db', team: 'citizen', desc: 'الطبيب - يختار شخصاً ليشفيه ويحميه' },
  GIRL: { id: 'girl', name: 'البنت السنك', icon: '👧', color: '#9b59b6', team: 'citizen', desc: 'المحقق - يكشف هوية لاعب في الليل' },
  JOKER: { id: 'joker', name: 'الجوكر', icon: '🤡', color: '#ffd700', team: 'citizen', desc: 'القناص - يستيقظ ليختار هدفاً (قاعدة خاصة)' },
  CITIZEN: { id: 'citizen', name: 'مواطن', icon: '🙂', color: '#95a5a6', team: 'citizen', desc: 'مواطن عادي - يصوت في النهار' }
};

const CARDS = [
  { suit: 'hearts', value: 'A', symbol: '♥', color: 'red', role: 'RED_ACE' },
  { suit: 'spades', value: 'A', symbol: '♠', color: 'black', role: 'BLACK_ACE' },
  { suit: 'hearts', value: '2', symbol: '♥', color: 'red', role: 'CITIZEN' },
  { suit: 'hearts', value: '3', symbol: '♥', color: 'red', role: 'CITIZEN' },
  { suit: 'hearts', value: '4', symbol: '♥', color: 'red', role: 'CITIZEN' },
  { suit: 'hearts', value: '5', symbol: '♥', color: 'red', role: 'CITIZEN' },
  { suit: 'hearts', value: '6', symbol: '♥', color: 'red', role: 'CITIZEN' },
  { suit: 'hearts', value: '7', symbol: '♥', color: 'red', role: 'CITIZEN' },
  { suit: 'hearts', value: '8', symbol: '♥', color: 'red', role: 'CITIZEN' },
  { suit: 'hearts', value: '9', symbol: '♥', color: 'red', role: 'CITIZEN' },
  { suit: 'hearts', value: '10', symbol: '♥', color: 'red', role: 'CITIZEN' },
  { suit: 'hearts', value: 'J', symbol: '♥', color: 'red', role: 'BOY' },
  { suit: 'hearts', value: 'Q', symbol: '♥', color: 'red', role: 'OLD_MAN' },
  { suit: 'hearts', value: 'K', symbol: '♥', color: 'red', role: 'GIRL' },
  { suit: 'diamonds', value: 'J', symbol: '♦', color: 'red', role: 'JOKER' },
  // Additional citizens from other suits
  { suit: 'diamonds', value: '2', symbol: '♦', color: 'red', role: 'CITIZEN' },
  { suit: 'diamonds', value: '3', symbol: '♦', color: 'red', role: 'CITIZEN' },
  { suit: 'diamonds', value: '4', symbol: '♦', color: 'red', role: 'CITIZEN' },
  { suit: 'diamonds', value: '5', symbol: '♦', color: 'red', role: 'CITIZEN' },
  { suit: 'diamonds', value: '6', symbol: '♦', color: 'red', role: 'CITIZEN' },
  { suit: 'diamonds', value: '7', symbol: '♦', color: 'red', role: 'CITIZEN' },
  { suit: 'diamonds', value: '8', symbol: '♦', color: 'red', role: 'CITIZEN' },
  { suit: 'diamonds', value: '9', symbol: '♦', color: 'red', role: 'CITIZEN' },
  { suit: 'diamonds', value: '10', symbol: '♦', color: 'red', role: 'CITIZEN' },
  { suit: 'clubs', value: '2', symbol: '♣', color: 'black', role: 'CITIZEN' },
  { suit: 'clubs', value: '3', symbol: '♣', color: 'black', role: 'CITIZEN' },
  { suit: 'clubs', value: '4', symbol: '♣', color: 'black', role: 'CITIZEN' },
  { suit: 'clubs', value: '5', symbol: '♣', color: 'black', role: 'CITIZEN' },
  { suit: 'clubs', value: '6', symbol: '♣', color: 'black', role: 'CITIZEN' },
  { suit: 'clubs', value: '7', symbol: '♣', color: 'black', role: 'CITIZEN' },
  { suit: 'clubs', value: '8', symbol: '♣', color: 'black', role: 'CITIZEN' },
  { suit: 'clubs', value: '9', symbol: '♣', color: 'black', role: 'CITIZEN' },
  { suit: 'clubs', value: '10', symbol: '♣', color: 'black', role: 'CITIZEN' },
  { suit: 'spades', value: '2', symbol: '♠', color: 'black', role: 'CITIZEN' },
  { suit: 'spades', value: '3', symbol: '♠', color: 'black', role: 'CITIZEN' },
  { suit: 'spades', value: '4', symbol: '♠', color: 'black', role: 'CITIZEN' },
  { suit: 'spades', value: '5', symbol: '♠', color: 'black', role: 'CITIZEN' },
  { suit: 'spades', value: '6', symbol: '♠', color: 'black', role: 'CITIZEN' },
  { suit: 'spades', value: '7', symbol: '♠', color: 'black', role: 'CITIZEN' },
  { suit: 'spades', value: '8', symbol: '♠', color: 'black', role: 'CITIZEN' },
  { suit: 'spades', value: '9', symbol: '♠', color: 'black', role: 'CITIZEN' },
  { suit: 'spades', value: '10', symbol: '♠', color: 'black', role: 'CITIZEN' }
];

// ==================== UTILITIES ====================
function generateId() { return Math.random().toString(36).substr(2, 9); }
function shuffle(array) {
  const arr = [...array];
  for (let i = arr.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [arr[i], arr[j]] = [arr[j], arr[i]];
  }
  return arr;
}
function showScreen(id) {
  document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
  document.getElementById(id).classList.add('active');
}
function logEvent(text, type = 'normal') {
  const time = new Date().toLocaleTimeString('ar-SA', { hour: '2-digit', minute: '2-digit' });
  const colors = { kill: 'event-kill', save: 'event-save', mute: 'event-mute', reveal: 'event-reveal', normal: '' };
  gameState.eventLog.unshift({ text, time, type });
  updateEventLog();
}
function updateEventLog() {
  const el = document.getElementById('event-log');
  if (!el) return;
  el.innerHTML = gameState.eventLog.map(e => {
    const colorClass = e.type === 'kill' ? 'event-kill' : e.type === 'save' ? 'event-save' : e.type === 'mute' ? 'event-mute' : e.type === 'reveal' ? 'event-reveal' : '';
    return `<div class="event-item ${colorClass}"><span class="event-time">[${e.time}]</span> ${e.text}</div>`;
  }).join('');
}

// ==================== SETUP ====================
let tempPlayers = [];
function toggleWinCondition(opt) {
  gameState.winCondition = opt;
  document.getElementById('win-toggle-1').classList.toggle('active', opt === 1);
  document.getElementById('win-toggle-2').classList.toggle('active', opt === 2);
}
function addPlayer() {
  const input = document.getElementById('player-input');
  const name = input.value.trim();
  if (!name) return alert('أدخل اسم اللاعب');
  if (tempPlayers.find(p => p.name === name)) return alert('الاسم موجود مسبقاً');
  tempPlayers.push({ id: generateId(), name });
  input.value = '';
  renderTempPlayers();
  document.getElementById('btn-start-game').disabled = tempPlayers.length < 5;
}
function removePlayer(id) {
  tempPlayers = tempPlayers.filter(p => p.id !== id);
  renderTempPlayers();
  document.getElementById('btn-start-game').disabled = tempPlayers.length < 5;
}
function renderTempPlayers() {
  const container = document.getElementById('setup-players-list');
  container.innerHTML = tempPlayers.map(p => `
    <div class="player-item">
      <div class="player-avatar">${p.name.charAt(0)}</div>
      <div class="player-info">
        <div class="player-name">${p.name}</div>
      </div>
      <button class="btn btn-danger btn-sm" onclick="removePlayer('${p.id}')">حذف</button>
    </div>
  `).join('');
}

// ==================== START GAME ====================
function startGame() {
  const adminName = document.getElementById('admin-name').value.trim();
  if (!adminName) return alert('أدخل اسم الأدمن');
  if (tempPlayers.length < 5) return alert('يجب أن يكون هناك 5 لاعبين على الأقل');

  gameState.adminName = adminName;
  gameState.players = [];

  // Select appropriate cards based on player count
  const count = tempPlayers.length;
  let selectedCards = [];

  // Always include special roles
  const specialCards = CARDS.filter(c => 
    c.role === 'RED_ACE' || c.role === 'BLACK_ACE' || 
    c.role === 'BOY' || c.role === 'OLD_MAN' || 
    c.role === 'GIRL' || c.role === 'JOKER'
  );
  selectedCards.push(...specialCards);

  // Fill rest with citizens
  const citizenCards = shuffle(CARDS.filter(c => c.role === 'CITIZEN'));
  const needed = count - selectedCards.length;
  selectedCards.push(...citizenCards.slice(0, needed));

  // Shuffle and assign
  const shuffledCards = shuffle(selectedCards);
  const shuffledPlayers = shuffle(tempPlayers);

  shuffledPlayers.forEach((p, i) => {
    const card = shuffledCards[i];
    const roleKey = card.role;
    gameState.players.push({
      id: p.id,
      name: p.name,
      role: roleKey,
      card: card,
      alive: true,
      muted: false,
      mutedNextDay: false,
      healed: false,
      revealed: false,
      sniperUsed: false,
      avatar: p.name.charAt(0)
    });
  });

  // Save to localStorage for join functionality
  localStorage.setItem('mafia_game', JSON.stringify(gameState));

  renderCards();
  showScreen('screen-roles');
}

function renderCards() {
  const container = document.getElementById('cards-container');
  container.innerHTML = gameState.players.map((p, i) => `
    <div class="playing-card card-back" id="card-${p.id}" onclick="flipCard('${p.id}')" style="cursor: pointer;">
      <div class="card-pattern"></div>
    </div>
  `).join('');
}

function flipCard(playerId) {
  const player = gameState.players.find(p => p.id === playerId);
  const cardEl = document.getElementById(`card-${playerId}`);
  const role = ROLES[player.role];

  cardEl.className = `playing-card ${player.card.color}`;
  cardEl.innerHTML = `
    <div class="card-value">${player.card.value}</div>
    <div class="card-suit">${player.card.symbol}</div>
    <div class="card-role">${role.icon} ${role.name}</div>
  `;
  cardEl.style.animation = 'fadeIn 0.5s ease';
  cardEl.onclick = null;
}

function revealAllCards() {
  gameState.players.forEach(p => flipCard(p.id));
  gameState.cardsRevealed = true;
}

function goToGame() {
  gameState.currentView = 'admin';
  showScreen('screen-admin');
  updateAdminView();
}

// ==================== JOIN ====================
function updateJoinSelect() {
  const saved = localStorage.getItem('mafia_game');
  const select = document.getElementById('join-player-select');
  select.innerHTML = '<option value="">-- اختر --</option>';
  if (!saved) return;
  const data = JSON.parse(saved);
  data.players.forEach(p => {
    select.innerHTML += `<option value="${p.id}">${p.name}</option>`;
  });
}

function joinAsPlayer() {
  const select = document.getElementById('join-player-select');
  const playerId = select.value;
  if (!playerId) return alert('اختر اسمك');

  const saved = localStorage.getItem('mafia_game');
  if (!saved) return alert('لا توجد لعبة نشطة');
  gameState = JSON.parse(saved);
  gameState.currentView = 'player';
  gameState.currentPlayerId = playerId;
  showScreen('screen-player');
  updatePlayerView();
}

function joinAsSpectator() {
  const saved = localStorage.getItem('mafia_game');
  if (!saved) return alert('لا توجد لعبة نشطة');
  gameState = JSON.parse(saved);
  gameState.currentView = 'spectator';
  showScreen('screen-spectator');
  updateSpectatorView();
}

// ==================== ADMIN VIEW ====================
function updateAdminView() {
  updateStats();
  renderAdminPlayers();
  renderAdminControls();
  updateEventLog();
}

function updateStats() {
  const mafiaAlive = gameState.players.filter(p => p.alive && (p.role === 'RED_ACE' || p.role === 'BLACK_ACE')).length;
  const mafiaTotal = gameState.players.filter(p => p.role === 'RED_ACE' || p.role === 'BLACK_ACE').length;
  const citizensAlive = gameState.players.filter(p => p.alive && p.role !== 'RED_ACE' && p.role !== 'BLACK_ACE').length;
  const totalAlive = gameState.players.filter(p => p.alive).length;

  document.getElementById('stat-mafia').textContent = gameState.winCondition === 1 ? mafiaTotal : mafiaAlive;
  document.getElementById('stat-citizen').textContent = citizensAlive;
  document.getElementById('stat-total').textContent = totalAlive;
  document.getElementById('stat-day').textContent = gameState.day;
  document.getElementById('stat-phase').textContent = gameState.phase === 'day' ? '☀️' : gameState.phase === 'night' ? '🌙' : '🗳️';
}

function renderAdminPlayers() {
  const container = document.getElementById('admin-players-list');
  container.innerHTML = gameState.players.map(p => {
    const role = ROLES[p.role];
    const statusClass = p.alive ? (p.muted ? 'status-muted' : 'status-alive') : 'status-dead';
    const statusText = p.alive ? (p.muted ? 'مسكوت' : 'حي') : 'ميت';
    const cardInfo = `${p.card.value}${p.card.symbol}`;

    return `
      <div class="player-item ${p.alive ? '' : 'dead'} ${p.muted ? 'muted' : ''}" style="margin-bottom: 8px;">
        <div class="player-avatar" style="background: ${role.color};">${role.icon}</div>
        <div class="player-info">
          <div class="player-name">${p.name} <span style="font-size: 0.8rem; opacity: 0.7;">(${cardInfo})</span></div>
          <div class="player-role">${role.name} - ${role.team === 'mafia' ? 'مافيا' : 'صالح'}</div>
        </div>
        <span class="player-status ${statusClass}">${statusText}</span>
      </div>
    `;
  }).join('');
}

function renderAdminControls() {
  const container = document.getElementById('phase-controls');

  if (gameState.gameOver) {
    container.innerHTML = '<div style="text-align: center; padding: 20px; color: var(--accent); font-size: 1.3rem; font-weight: 700;">🏁 اللعبة انتهت</div>';
    return;
  }

  if (gameState.phase === 'day') {
    container.innerHTML = `
      <div style="text-align: center;">
        <div style="font-size: 1.3rem; color: var(--accent); margin-bottom: 16px; font-weight: 700;">☀️ النهار - التصويت والنقاش</div>
        <p style="color: var(--text-muted); margin-bottom: 20px;">اللاعبون يتناقشون ويصوتون لطرد شخص</p>
        <div id="voting-section">
          <div class="voting-grid">
            ${gameState.players.filter(p => p.alive && !p.muted).map(p => `
              <div class="vote-card" id="vote-card-${p.id}" onclick="adminVote('${p.id}')">
                <div style="font-weight: 700;">${p.name}</div>
                <div class="vote-count" id="vote-count-${p.id}">0</div>
                <div style="font-size: 0.8rem; color: var(--text-muted);">صوت</div>
              </div>
            `).join('')}
          </div>
          <div class="btn-group" style="margin-top: 20px;">
            <button class="btn btn-danger" onclick="endVoting()">🗳️ إنهاء التصويت وطرد الأعلى</button>
            <button class="btn btn-dark" onclick="skipVoting()">⏭️ تخطي التصويت</button>
          </div>
        </div>
        <div class="btn-group" style="margin-top: 20px;">
          <button class="btn btn-primary btn-lg" onclick="startNight()">🌙 بدء الليل</button>
        </div>
      </div>
    `;
    // Reset votes display
    renderVotes();
  } else if (gameState.phase === 'night') {
    renderNightControls();
  }
}

let adminVotes = {};
function adminVote(targetId) {
  // Admin can assign votes for players (simulating player votes)
  if (!adminVotes[targetId]) adminVotes[targetId] = 0;
  adminVotes[targetId]++;
  renderVotes();
}

function renderVotes() {
  if (!document.getElementById('voting-section')) return;
  // Clear all first
  gameState.players.forEach(p => {
    const countEl = document.getElementById(`vote-count-${p.id}`);
    if (countEl) countEl.textContent = adminVotes[p.id] || 0;
    const cardEl = document.getElementById(`vote-card-${p.id}`);
    if (cardEl) cardEl.classList.toggle('voted', (adminVotes[p.id] || 0) > 0);
  });
}

function endVoting() {
  // Find player with most votes
  let maxVotes = -1;
  let targets = [];
  for (const [id, count] of Object.entries(adminVotes)) {
    if (count > maxVotes) { maxVotes = count; targets = [id]; }
    else if (count === maxVotes) targets.push(id);
  }

  if (maxVotes <= 0) {
    alert('لا توجد أصوات');
    return;
  }

  if (targets.length > 1) {
    alert('تعادل في الأصوات! أعد التصويت أو تخطَّ');
    return;
  }

  const target = gameState.players.find(p => p.id === targets[0]);
  if (!target) return;

  if (confirm(`هل تريد طرد ${target.name}؟`)) {
    eliminatePlayer(target.id, 'vote');
    adminVotes = {};
  }
}

function skipVoting() {
  adminVotes = {};
  logEvent('تم تخطي التصويت');
  renderAdminControls();
}

// ==================== NIGHT PHASE ====================
function startNight() {
  gameState.phase = 'night';
  gameState.nightStep = 0;
  gameState.nightActions = {};
  // Clear muted status from previous day (mutedNextDay becomes muted)
  gameState.players.forEach(p => { p.muted = false; });

  // Show night overlay
  document.getElementById('night-overlay').style.display = 'flex';
}

function startNightPhase() {
  document.getElementById('night-overlay').style.display = 'none';
  gameState.nightStep = 1;
  renderAdminControls();
  updateAdminView();
}

function renderNightControls() {
  const container = document.getElementById('phase-controls');
  const steps = [
    { num: 1, key: 'mafiaKill', title: '🔴 مافيا القتل', desc: 'الآس الأحمر يختار ضحية للقتل', icon: '🃏' },
    { num: 2, key: 'mafiaMute', title: '⚫ مافيا التسكيت', desc: 'الآس الأسود يختار ضحية للتسكيت', icon: '🃏' },
    { num: 3, key: 'doctor', title: '👴 الشايب (الطبيب)', desc: 'يختار لاعباً ليشفيه', icon: '👴' },
    { num: 4, key: 'sniper', title: '🤡 الجوكر (القناص)', desc: 'يختار هدفاً للقنص', icon: '🤡' },
    { num: 5, key: 'detective', title: '👧 البنت السنك (المحقق)', desc: 'يختار لاعباً ليكشف هويته', icon: '👧' },
    { num: 6, key: 'dayBreak', title: '☀️ بزوغ النهار', desc: 'حساب النتائج وإعلان الأحداث', icon: '☀️' }
  ];

  let html = `<div class="phase-steps">`;
  steps.forEach(step => {
    let cls = '';
    if (step.num < gameState.nightStep) cls = 'done';
    else if (step.num === gameState.nightStep) cls = 'active';
    html += `<div class="phase-step ${cls}">${step.num}. ${step.title}</div>`;
  });
  html += `</div>`;

  if (gameState.nightStep >= 1 && gameState.nightStep <= 5) {
    const step = steps[gameState.nightStep - 1];
    const alivePlayers = gameState.players.filter(p => p.alive);

    html += `
      <div class="action-panel">
        <div class="action-title">${step.icon} ${step.title}</div>
        <div class="action-desc">${step.desc}</div>
        <div class="action-targets">
          ${alivePlayers.map(p => `
            <button class="target-btn" id="target-${p.id}" onclick="selectNightTarget('${step.key}', '${p.id}')">
              ${p.name}
            </button>
          `).join('')}
        </div>
        <div class="btn-group">
          <button class="btn btn-primary" onclick="confirmNightAction('${step.key}')">✅ تأكيد</button>
          <button class="btn btn-dark" onclick="skipNightAction('${step.key}')">⏭️ تخطي</button>
        </div>
      </div>
    `;
  } else if (gameState.nightStep === 6) {
    html += `
      <div class="action-panel">
        <div class="action-title">☀️ بزوغ النهار</div>
        <div class="action-desc">اضغط لحساب نتائج الليل وإعلان الأحداث</div>
        <div class="btn-group">
          <button class="btn btn-accent btn-lg" onclick="processNightResults()">🌅 إعلان نتائج الليل</button>
        </div>
      </div>
    `;
  }

  container.innerHTML = html;
}

let currentNightSelection = null;
function selectNightTarget(action, playerId) {
  currentNightSelection = playerId;
  document.querySelectorAll('.target-btn').forEach(btn => btn.classList.remove('selected'));
  const btn = document.getElementById(`target-${playerId}`);
  if (btn) btn.classList.add('selected');
}

function confirmNightAction(action) {
  if (!currentNightSelection) return alert('اختر هدفاً أولاً');
  gameState.nightActions[action] = currentNightSelection;

  const target = gameState.players.find(p => p.id === currentNightSelection);
  logEvent(`${getActionName(action)}: ${target.name}`, action === 'mafiaKill' ? 'kill' : action === 'doctor' ? 'save' : action === 'mafiaMute' ? 'mute' : 'normal');

  currentNightSelection = null;
  gameState.nightStep++;

  // Auto-skip sniper if already used
  if (gameState.nightStep === 4) {
    const sniper = gameState.players.find(p => p.role === 'JOKER' && p.alive);
    if (!sniper || sniper.sniperUsed) {
      logEvent('القناص فقد قدرته أو مات - تخطي');
      gameState.nightStep++;
    }
  }

  renderAdminControls();
  updateAdminView();
}

function skipNightAction(action) {
  gameState.nightActions[action] = null;
  gameState.nightStep++;
  renderAdminControls();
  updateAdminView();
}

function getActionName(action) {
  const names = {
    mafiaKill: 'مافيا القتل', mafiaMute: 'مافيا التسكيت',
    doctor: 'الطبيب', sniper: 'القناص', detective: 'المحقق'
  };
  return names[action] || action;
}

// ==================== PROCESS NIGHT RESULTS ====================
function processNightResults() {
  const actions = gameState.nightActions;
  let results = [];
  let deaths = [];

  // 1. Mafia Kill
  let killTarget = null;
  if (actions.mafiaKill) {
    killTarget = gameState.players.find(p => p.id === actions.mafiaKill);
    if (killTarget) {
      // Check if healed
      if (actions.doctor === actions.mafiaKill) {
        results.push(`🛡️ ${killTarget.name} تم إنقاذه بواسطة الطبيب!`);
        killTarget.healed = true;
      } else {
        results.push(`💀 ${killTarget.name} قُتل بواسطة المافيا!`);
        deaths.push(killTarget.id);
      }
    }
  }

  // 2. Mafia Mute
  if (actions.mafiaMute) {
    const muteTarget = gameState.players.find(p => p.id === actions.mafiaMute);
    if (muteTarget && muteTarget.alive && !deaths.includes(muteTarget.id)) {
      muteTarget.mutedNextDay = true;
      results.push(`🤐 ${muteTarget.name} تم تسكيته (لا يتكلم ولا يصوت غداً)`);
    }
  }

  // 3. Doctor (already handled above)
  if (actions.doctor && actions.doctor !== actions.mafiaKill) {
    const healTarget = gameState.players.find(p => p.id === actions.doctor);
    if (healTarget) {
      healTarget.healed = true;
      results.push(`💚 ${healTarget.name} تم شفاؤه (محمي)`);
    }
  }

  // 4. Sniper (Joker)
  if (actions.sniper) {
    const sniper = gameState.players.find(p => p.role === 'JOKER' && p.alive);
    const sniperTarget = gameState.players.find(p => p.id === actions.sniper);
    if (sniper && sniperTarget) {
      const isMafia = sniperTarget.role === 'RED_ACE' || sniperTarget.role === 'BLACK_ACE';
      if (isMafia) {
        results.push(`🎯 القناص ${sniper.name} أصاب مافيا! ${sniperTarget.name} مات!`);
        results.push(`⚠️ القناص فقد قدرته للأبد`);
        sniper.sniperUsed = true;
        deaths.push(sniperTarget.id);
      } else {
        results.push(`💥 القناص ${sniper.name} أصاب مواطن صالح!`);
        results.push(`💀 ${sniper.name} و ${sniperTarget.name} ماتا معاً!`);
        deaths.push(sniper.id);
        deaths.push(sniperTarget.id);
      }
    }
  }

  // 5. Detective
  if (actions.detective) {
    const detectTarget = gameState.players.find(p => p.id === actions.detective);
    if (detectTarget) {
      const isMafia = detectTarget.role === 'RED_ACE' || detectTarget.role === 'BLACK_ACE';
      results.push(`🔍 المحقق اكتشف: ${detectTarget.name} هو ${isMafia ? 'مافيا 🃏' : 'صالح ✅'}`);
      detectTarget.revealed = true;
    }
  }

  // Apply deaths (and Boy's revenge)
  const uniqueDeaths = [...new Set(deaths)];
  uniqueDeaths.forEach(deathId => {
    const player = gameState.players.find(p => p.id === deathId);
    if (player && player.alive) {
      // Check Boy's revenge
      if (player.role === 'BOY') {
        // Boy will choose someone to take with him - admin handles this manually
        results.push(`⚡ ${player.name} (الولد الصالح) مات! سينتقم بسحب شخص معه...`);
      }
      player.alive = false;
    }
  });

  // Apply mute for next day
  gameState.players.forEach(p => {
    if (p.mutedNextDay) { p.muted = true; p.mutedNextDay = false; }
  });

  // Show results
  showDayResults(results, uniqueDeaths);

  gameState.phase = 'day';
  gameState.day++;
  updateAdminView();
  checkWinCondition();
}

function showDayResults(results, deaths) {
  const html = `
    <div class="modal-overlay" id="day-results-modal" onclick="closeDayResults()">
      <div class="modal-content" style="max-width: 600px;" onclick="event.stopPropagation()">
        <div class="day-results" style="margin: 0;">
          <h2>☀️ بزوغ النهار - اليوم ${gameState.day}</h2>
          <div style="text-align: right; margin: 20px 0;">
            ${results.map(r => `<div class="result-item">${r}</div>`).join('')}
          </div>
          ${deaths.length > 0 ? `<div style="color: var(--danger); font-weight: 700; margin-top: 16px;">☠️ عدد الوفيات: ${deaths.length}</div>` : ''}
          <button class="btn btn-accent btn-lg" onclick="closeDayResults()" style="margin-top: 20px;">متابعة</button>
        </div>
      </div>
    </div>
  `;
  document.body.insertAdjacentHTML('beforeend', html);
}

function closeDayResults() {
  const modal = document.getElementById('day-results-modal');
  if (modal) modal.remove();

  // Handle Boy's revenge if he died
  const deadBoy = gameState.players.find(p => p.role === 'BOY' && !p.alive && !p.boyRevengeDone);
  if (deadBoy) {
    deadBoy.boyRevengeDone = true;
    showBoyRevenge(deadBoy);
  }
}

function showBoyRevenge(boy) {
  const alivePlayers = gameState.players.filter(p => p.alive && p.id !== boy.id);
  const html = `
    <div class="modal-overlay" id="boy-revenge-modal">
      <div class="modal-content" style="max-width: 500px;">
        <div style="font-size: 3rem; margin-bottom: 16px;">👦</div>
        <div class="modal-title" style="color: var(--success);">الولد الصالح ينتقم!</div>
        <p style="color: var(--text-muted); margin-bottom: 20px;">${boy.name} مات وسيأخذ شخصاً معه...</p>
        <div class="action-targets">
          ${alivePlayers.map(p => `
            <button class="target-btn" onclick="executeBoyRevenge('${boy.id}', '${p.id}')">${p.name}</button>
          `).join('')}
        </div>
        <button class="btn btn-dark" onclick="document.getElementById('boy-revenge-modal').remove()" style="margin-top: 16px;">تخطي</button>
      </div>
    </div>
  `;
  document.body.insertAdjacentHTML('beforeend', html);
}

function executeBoyRevenge(boyId, targetId) {
  const target = gameState.players.find(p => p.id === targetId);
  if (target) {
    target.alive = false;
    logEvent(`⚡ الولد الصالح سحب ${target.name} معه في الموت!`, 'kill');
  }
  document.getElementById('boy-revenge-modal').remove();
  updateAdminView();
  checkWinCondition();
}

// ==================== WIN CONDITION ====================
function checkWinCondition() {
  const mafiaTotal = gameState.players.filter(p => p.role === 'RED_ACE' || p.role === 'BLACK_ACE').length;
  const mafiaAlive = gameState.players.filter(p => p.alive && (p.role === 'RED_ACE' || p.role === 'BLACK_ACE')).length;
  const citizensAlive = gameState.players.filter(p => p.alive && p.role !== 'RED_ACE' && p.role !== 'BLACK_ACE').length;

  let mafiaWins = false;
  let citizensWins = false;

  if (mafiaAlive === 0) {
    citizensWins = true;
  } else if (gameState.winCondition === 1) {
    // Option 1: mafia total == citizens alive
    if (mafiaTotal >= citizensAlive) mafiaWins = true;
  } else {
    // Option 2: mafia alive == citizens alive
    if (mafiaAlive >= citizensAlive) mafiaWins = true;
  }

  if (mafiaWins || citizensWins) {
    gameState.gameOver = true;
    showWinner(mafiaWins ? 'mafia' : 'citizens');
  }
}

function showWinner(winner) {
  const title = winner === 'mafia' ? '🔴 المافيا تفوز!' : '✅ الصالحون يفوزون!';
  const colorClass = winner === 'mafia' ? 'mafia-win' : 'citizens-win';
  const emoji = winner === 'mafia' ? '🃏' : '🛡️';

  const html = `
    <div class="modal-overlay" id="winner-modal-display">
      <div class="modal-content ${colorClass}">
        <div style="font-size: 4rem; margin-bottom: 16px;">${emoji}</div>
        <div class="modal-title ${colorClass}">${title}</div>
        <div style="margin: 20px 0; text-align: right;">
          <div style="font-weight: 700; color: var(--accent); margin-bottom: 12px;">اللاعبون:</div>
          ${gameState.players.map(p => {
            const role = ROLES[p.role];
            const status = p.alive ? '🟢' : '🔴';
            return `<div style="padding: 6px 0; border-bottom: 1px solid var(--border);">${status} ${p.name} - ${role.icon} ${role.name}</div>`;
          }).join('')}
        </div>
        <button class="btn btn-primary btn-lg" onclick="location.reload()">🔄 لعبة جديدة</button>
      </div>
    </div>
  `;
  document.body.insertAdjacentHTML('beforeend', html);
}

function confirmEndGame() {
  if (confirm('هل تريد إنهاء اللعبة؟')) {
    localStorage.removeItem('mafia_game');
    location.reload();
  }
}

// ==================== PLAYER VIEW ====================
function updatePlayerView() {
  const player = gameState.players.find(p => p.id === gameState.currentPlayerId);
  if (!player) return;

  const role = ROLES[player.role];
  const container = document.getElementById('player-view-content');

  let statusHtml = '';
  if (!player.alive) {
    statusHtml = `<div style="color: var(--danger); font-size: 1.5rem; font-weight: 700; margin: 20px 0;">☠️ أنت ميت</div>`;
  } else if (player.muted) {
    statusHtml = `<div style="color: var(--warning); font-size: 1.2rem; font-weight: 700; margin: 20px 0;">🤐 أنت مسكوت (لا تتكلم ولا تصوت)</div>`;
  } else {
    statusHtml = `<div style="color: var(--success); font-size: 1.2rem; font-weight: 700; margin: 20px 0;">🟢 أنت حي</div>`;
  }

  container.innerHTML = `
    <div style="font-size: 4rem; margin-bottom: 16px;">${role.icon}</div>
    <div style="font-size: 2rem; font-weight: 900; color: ${role.color}; margin-bottom: 8px;">${role.name}</div>
    <div style="color: var(--text-muted); margin-bottom: 20px; line-height: 1.6;">${role.desc}</div>
    <div style="background: var(--bg-dark); padding: 20px; border-radius: 16px; margin: 20px 0; border: 2px solid ${role.color};">
      <div style="font-size: 3rem; margin-bottom: 8px;">${player.card.value}${player.card.symbol}</div>
      <div style="font-size: 1.2rem; font-weight: 700;">${player.card.value === 'A' ? 'آس' : player.card.value === 'J' ? 'جاك' : player.card.value === 'Q' ? 'كوين' : player.card.value === 'K' ? 'كينج' : player.card.value} ${player.card.symbol}</div>
    </div>
    ${statusHtml}
    <div style="margin-top: 20px; padding: 16px; background: var(--bg-dark); border-radius: 12px; text-align: right;">
      <div style="font-weight: 700; color: var(--accent); margin-bottom: 8px;">📊 حالة اللعبة:</div>
      <div style="color: var(--text-muted);">اليوم: ${gameState.day} | الفترة: ${gameState.phase === 'day' ? '☀️ نهار' : '🌙 ليل'}</div>
    </div>
    <div class="btn-group" style="margin-top: 24px;">
      <button class="btn btn-dark" onclick="location.reload()">🔙 خروج</button>
    </div>
  `;
}

// ==================== SPECTATOR VIEW ====================
function updateSpectatorView() {
  const container = document.getElementById('spectator-players-list');
  container.innerHTML = gameState.players.map(p => {
    const status = p.alive ? (p.muted ? '🤐 مسكوت' : '🟢 حي') : '🔴 ميت';
    return `
      <div class="player-item ${p.alive ? '' : 'dead'}" style="margin-bottom: 8px;">
        <div class="player-avatar" style="background: #555;">?</div>
        <div class="player-info">
          <div class="player-name">${p.name}</div>
          <div class="player-role">الدور: مخفي</div>
        </div>
        <span class="player-status ${p.alive ? (p.muted ? 'status-muted' : 'status-alive') : 'status-dead'}">${status}</span>
      </div>
    `;
  }).join('');
}

